    "test:app:init-readiness": "node --loader ./tests/helpers/alias-loader.mjs tests/app/private-init-readiness.test.ts",
    "test:app:stream-state": "node --loader ./tests/helpers/alias-loader.mjs tests/app/stream-lifecycle-state.test.ts",
    "test:treasury:logic": "node --loader ./tests/helpers/alias-loader.mjs tests/treasury/private-swap-config.test.ts",
    "test:magicblock:e2e": "node tests/magicblock/api.e2e.ts",
    "deploy:payroll:devnet": "sh ./scripts/payroll/devnet/deploy.sh",
    "check:payroll:idl-parity": "node ./scripts/payroll/check-idl-parity.js"
  },
