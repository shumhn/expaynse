{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.4",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "payroll:build": "anchor build",
    "payroll:test": "anchor test",
    "payroll:crank": "tsx scripts/payroll/crank.ts",
