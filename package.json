    "payroll:verify:devnet": "node scripts/payroll/verify-devnet.js",
    "test:payroll:devnet": "ts-mocha -p ./tsconfig.payroll.json -t 300000 tests/payroll/payroll.ts",
    "test:app:smoke": "node --env-file=.env --loader ./tests/helpers/alias-loader.mjs tests/app/route-smoke.ts",
